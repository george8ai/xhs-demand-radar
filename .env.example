# 新榜认证信息（从 Chrome DevTools 获取）
# 打开 Chrome → 登录 newrank.cn → F12 → Network tab
# 找任意 gw.newrank.cn 请求 → Request Headers

# n-token 字段的值
NEWRANK_TOKEN=your_n_token_here

# cookie 字段的完整值
NEWRANK_COOKIE=your_full_cookie_string_here

# Discord Webhook URL
# Discord 频道设置 → Integrations → Webhooks → 复制 URL
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url_here
